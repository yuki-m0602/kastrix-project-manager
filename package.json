{
  "scripts": {
    "lint": "eslint ui/js/*.js ui/data/*.js",
    "lint:fix": "eslint ui/js/*.js ui/data/*.js --fix",
    "rustfmt": "cargo fmt --manifest-path src-tauri/Cargo.toml",
    "clippy": "cargo clippy --manifest-path src-tauri/Cargo.toml",
    "tauri": "tauri",
    "dev": "npm run css:watch & npx live-server ui --port=1420 --no-browser",
    "css:watch": "npx @tailwindcss/cli -i ./ui/src/styles.css -o ./ui/vendor/tailwind.css --minify --content ./ui/index.html --content ./ui/js/*.js --watch",
    "css:build": "npx @tailwindcss/cli -i ./ui/src/styles.css -o ./ui/vendor/tailwind.css --minify --content ./ui/index.html --content ./ui/js/*.js",
    "build:ui": "npm run css:build",
    "build:exe": "npm run build:ui && cargo build --release --manifest-path src-tauri/Cargo.toml",
    "start": "npm run dev & npx tauri dev"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^8.57.0",
    "http-server": "^14.1.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1"
  },
  "dependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "live-server": "^1.2.2"
  }
}
